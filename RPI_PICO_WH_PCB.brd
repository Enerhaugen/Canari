<designrules name="Fusion Electronics Design Rules">
<param name="mdWireWire" value="0.4mm"/>
<param name="mdWirePad" value="0.4mm"/>
<param name="mdWireVia" value="0.4mm"/>
<param name="mdPadPad" value="0.4mm"/>
<param name="mdPadVia" value="0.4mm"/>
<param name="mdViaVia" value="6mil"/>
<param name="mdSmdPad" value="6mil"/>
<param name="mdSmdVia" value="6mil"/>
<param name="mdSmdSmd" value="6mil"/>
